generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Telemetry {
  id         Int      @id @default(autoincrement())
  distance   Float
  height     Float
  pwm        Int
  error      Float
  wifi       Int
  alarm      Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model Config {
  id         Int      @id @default(1)
  setpoint   Float
  kp         Float
  ki         Float
  kd         Float
  resetToken Int      @default(0)
  updatedAt  DateTime @updatedAt
}